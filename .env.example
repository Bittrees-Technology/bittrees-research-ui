# Bittrees Research — environment configuration
# Copy to .env (local) and set the same in the Vercel project settings.

# ── Frontend (VITE_*, exposed to the browser) ───────────────────────────────

# WalletConnect / Reown project id. Required for WalletConnect wallets; injected
# wallets (MetaMask, etc.) work without it. https://cloud.reown.com
VITE_WALLETCONNECT_PROJECT_ID=

# Optional dedicated mainnet RPC (Alchemy/Infura/publicnode). Falls back to a
# public transport if unset.
VITE_MAINNET_RPC_URL=

# Alchemy key for membership-NFT lookups (browser). Domain-restrict it on the
# Alchemy dashboard. A working public key is bundled as a fallback.
VITE_ALCHEMY_API_KEY=

# Show Sepolia / Base Sepolia testnets in the wallet picker.
VITE_ENABLE_TESTNETS=false

# Base URL Push uses to enforce room gates. Defaults to the production origin.
# VITE_GATE_URL=https://research.bittrees.org/api/gate

# Push community room chatIds (filled once an admin creates each gated group;
# the runtime registry in Vercel KV takes precedence over these).
# VITE_PUSH_ROOM_MEMBERS=
# VITE_PUSH_ROOM_PREFERRED=
# VITE_PUSH_ROOM_INDEX=
# VITE_PUSH_ROOM_GUILD=
# VITE_PUSH_ROOM_ANNOUNCEMENTS=

# ── Serverless API (server-side only — NOT exposed to the browser) ──────────

# Server RPC for the /api/gate token/Safe/ENS reads. Use a node with NO domain
# restriction (a browser-allowlisted key 403s from serverless).
# MAINNET_RPC_URL=

# Vercel KV (Upstash) — backs the roles/rooms/moderation registry + cross-device
# sync. Without it the app still runs (built-in rooms via env, no custom rooms).
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
